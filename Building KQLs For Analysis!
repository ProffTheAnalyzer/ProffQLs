New IP.

Working. 

// ========= Parameters =========
let userUpn = "example@gmail.com";
let suspiciousIP = "8.8.8.8";
let lookback = 90d;
let pivotWindow = 2h;

// ========= Base normalize (SigninLogs only) =========
let base =
SigninLogs
| where TimeGenerated > ago(lookback)
| extend
    Country  = tostring(LocationDetails.countryOrRegion),
    State    = tostring(LocationDetails.state),
    City     = tostring(LocationDetails.city),
    DeviceId = tostring(DeviceDetail.deviceId),
    DeviceName = tostring(DeviceDetail.displayName),
    TrustType = tostring(DeviceDetail.trustType),
    IsCompliant = tobool(DeviceDetail.isCompliant),
    IsManaged   = tobool(DeviceDetail.isManaged)
| extend
    JoinState = case(
        TrustType has "Hybrid", "Hybrid Azure AD joined",
        TrustType has "Azure AD joined", "Azure AD joined",
        TrustType has "Azure AD registered", "Azure AD registered",
        isempty(TrustType), "Unknown",
        TrustType
    );

// 1) All sign-ins for THIS user + THIS IP
let userIpEvents =
base
| where UserPrincipalName =~ userUpn
| where IPAddress == suspiciousIP
| project TimeGenerated, UserPrincipalName, AppDisplayName, IPAddress,
          Country, State, City, ClientAppUsed, ConditionalAccessStatus,
          ResultType, ResultDescription,
          DeviceName, DeviceId, JoinState, TrustType, IsCompliant, IsManaged,
          UserAgent, CorrelationId;

// 2) Summary: first/last + counts for this user/IP
let userIpFirstLast =
base
| where UserPrincipalName =~ userUpn
| where IPAddress == suspiciousIP
| summarize FirstSeen=min(TimeGenerated), LastSeen=max(TimeGenerated),
            Attempts=count(),
            Successes=countif(ResultType == 0),
            Failures=countif(ResultType != 0);

// 3) Context: is this IP hitting many users?
let ipAcrossUsers =
base
| where IPAddress == suspiciousIP
| summarize Users=dcount(UserPrincipalName),
            Total=count(),
            Successes=countif(ResultType == 0),
            Failures=countif(ResultType != 0),
            SampleUsers=make_set(UserPrincipalName, 25);

// 4) Pivot: show all sign-ins for this user around each user+IP event time
let userAround =
base
| where UserPrincipalName =~ userUpn
| join kind=inner (
    userIpEvents
    | project EventTime=TimeGenerated, UserPrincipalName
) on UserPrincipalName
| where TimeGenerated between (EventTime - pivotWindow .. EventTime + pivotWindow)
| project TimeGenerated, EventTime, UserPrincipalName,
          AppDisplayName, IPAddress, Country, State, City,
          ClientAppUsed, ConditionalAccessStatus, ResultType, ResultDescription,
          DeviceName, DeviceId, JoinState, TrustType, IsCompliant, IsManaged,
          UserAgent, CorrelationId;

// ========= Output (Sections) =========
union
(
    userIpFirstLast
    | extend Section="Summary: User+IP", UserPrincipalName=userUpn, IPAddress=suspiciousIP
    | project Section, TimeGenerated=LastSeen, UserPrincipalName, IPAddress,
              Metric1=strcat("FirstSeen=", tostring(FirstSeen)),
              Metric2=strcat("LastSeen=", tostring(LastSeen)),
              Metric3=strcat("Attempts=", tostring(Attempts), " Successes=", tostring(Successes), " Failures=", tostring(Failures))
),
(
    ipAcrossUsers
    | extend Section="Summary: IP across users", IPAddress=suspiciousIP
    | project Section, TimeGenerated=now(), UserPrincipalName="", IPAddress,
              Metric1=strcat("Users=", tostring(Users)),
              Metric2=strcat("Total=", tostring(Total), " Successes=", tostring(Successes), " Failures=", tostring(Failures)),
              Metric3=strcat("SampleUsers=", tostring(SampleUsers))
),
(
    userIpEvents
    | extend Section="Events: User+IP"
    | project Section, TimeGenerated, UserPrincipalName, IPAddress, AppDisplayName,
              ResultType, ResultDescription, ConditionalAccessStatus,
              Country, State, City,
              DeviceName, DeviceId, JoinState, TrustType, IsCompliant, IsManaged,
              UserAgent, CorrelationId
),
(
    userAround
    | extend Section="Pivot: User around event"
    | project Section, TimeGenerated, UserPrincipalName, IPAddress, AppDisplayName,
              ResultType, ResultDescription, ConditionalAccessStatus,
              Country, State, City,
              DeviceName, DeviceId, JoinState, TrustType, IsCompliant, IsManaged,
              UserAgent, CorrelationId,
              Metric1=strcat("EventTime=", tostring(EventTime))
)
| order by Section asc, TimeGenerated desc





