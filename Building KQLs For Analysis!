With Aad and IdentityLogonEvents

let userUpn = "example@gmail.com";
let suspiciousIP = "8.8.8.8";
let lookback = 30d;
let pivotWindow = 2h;

// 1) All sign-in activity for THIS user/IP (interactive + non-interactive + service principal)
let userIpEvents =
union isfuzzy=true SigninLogs, AADNonInteractiveUserSignInLogs, AADServicePrincipalSignInLogs
| where TimeGenerated > ago(lookback)
| where IPAddress == suspiciousIP
| where UserPrincipalName =~ userUpn or tostring(ServicePrincipalName) =~ userUpn
| extend
    Country = tostring(LocationDetails.countryOrRegion),
    State   = tostring(LocationDetails.state),
    City    = tostring(LocationDetails.city),
    DeviceId = tostring(DeviceDetail.deviceId),
    DeviceName = tostring(DeviceDetail.displayName)
| project TimeGenerated, Type, UserPrincipalName, ServicePrincipalName, AppDisplayName,
          IPAddress, Country, State, City, ClientAppUsed, ConditionalAccessStatus,
          ResultType, ResultDescription, DeviceName, DeviceId, UserAgent, CorrelationId
| order by TimeGenerated desc;

// 2) Has THIS user seen THIS IP before? (baseline)
let userSeenIpBefore =
SigninLogs
| where TimeGenerated > ago(lookback)
| where UserPrincipalName =~ userUpn
| where ResultType == 0
| summarize Seen=count() by IPAddress
| where IPAddress == suspiciousIP
| summarize SeenBefore = iif(count() > 0, true, false);

let userIpFirstLast =
SigninLogs
| where TimeGenerated > ago(lookback)
| where UserPrincipalName =~ userUpn
| where IPAddress == suspiciousIP
| summarize FirstSeen=min(TimeGenerated), LastSeen=max(TimeGenerated), Attempts=count(),
          Successes=countif(ResultType==0), Failures=countif(ResultType!=0);

// 3) Is this IP hitting MANY users? (spray / proxy / shared NAT indicator)
let ipAcrossUsers =
SigninLogs
| where TimeGenerated > ago(lookback)
| where IPAddress == suspiciousIP
| summarize Users=dcount(UserPrincipalName), Total=count(),
            Successes=countif(ResultType==0), Failures=countif(ResultType!=0),
            SampleUsers=make_set(UserPrincipalName, 25);

// 4) Tight time pivot: show all sign-ins for that user around the suspicious event times
let eventTimes =
userIpEvents
| summarize Times=make_list(TimeGenerated, 50);

let userAround =
union isfuzzy=true SigninLogs, AADNonInteractiveUserSignInLogs
| where TimeGenerated > ago(lookback)
| where UserPrincipalName =~ userUpn
| extend
    Country = tostring(LocationDetails.countryOrRegion),
    State   = tostring(LocationDetails.state),
    City    = tostring(LocationDetails.city)
| project TimeGenerated, Type, AppDisplayName, IPAddress, Country, State, City,
          ClientAppUsed, ConditionalAccessStatus, ResultType, ResultDescription, UserAgent;

// OUTPUT: summaries + the raw events
print FocusUser=userUpn, FocusIP=suspiciousIP
| union (userIpFirstLast | project FocusUser=userUpn, FocusIP=suspiciousIP, FirstSeen, LastSeen, Attempts, Successes, Failures)
| union (ipAcrossUsers   | project FocusUser=userUpn, FocusIP=suspiciousIP, Users, Total, Successes, Failures, SampleUsers)
| union (userIpEvents    | extend FocusUser=userUpn, FocusIP=suspiciousIP)
| union (userAround
        | where exists (
            userIpEvents
            | project TimeGenerated
            | extend start=TimeGenerated - pivotWindow, end=TimeGenerated + pivotWindow
        )
) 


All-in-one: suspicious URL click → impacted users → post-click sign-in risk (SigninLogs)

// ===============================
// URL click -> impacted users -> sign-in check
// ===============================
let suspiciousUrl = "http://example.bad/landing";   // <-- put your URL (exact or substring)
let clickLookback = 7d;                              // how far back to look for clicks
let postClickWindow = 48h;                           // sign-in window after first click
let baselineWindow = 30d;                            // baseline period prior to click
let baselineBuffer = 2h;                             // exclude the last 2h before click from baseline

// ---- 1) Get click events and extract users who clicked ----
let ClickEvents =
union isfuzzy=true UrlClickEvents, EmailUrlInfo
| where TimeGenerated > ago(clickLookback)
| extend
    ClickUrl = coalesce(tostring(Url), tostring(UrlChain), tostring(NetworkMessageId), tostring(ThreatTypes)), // fallback if schema differs
    UserUpn  = coalesce(tostring(AccountUpn), tostring(UserPrincipalName), tostring(UserId),
                       tostring(RecipientEmailAddress), tostring(Recipient), tostring(ActorUpn))
| where isnotempty(UserUpn)
| where tostring(ClickUrl) has suspiciousUrl or tostring(Url) has suspiciousUrl
| project ClickTime=TimeGenerated, UserUpn, ClickUrl, ActionType, ThreatTypes, NetworkMessageId;

let ClickedUsers =
ClickEvents
| summarize ClickCount=count(), FirstClick=min(ClickTime), LastClick=max(ClickTime), SampleUrls=make_set(ClickUrl, 5)
  by UserUpn;

// ---- 2) Build per-user baseline IP + Country sets (before first click) ----
let Baseline =
ClickedUsers
| join kind=inner (
    SigninLogs
    | where TimeGenerated > ago(baselineWindow + clickLookback)
    | where ResultType == 0
    | extend Country = tostring(LocationDetails.countryOrRegion)
    | project UserUpn=UserPrincipalName, TimeGenerated, IPAddress, Country
) on UserUpn
| where TimeGenerated between (FirstClick - baselineWindow .. FirstClick - baselineBuffer)
| summarize BaselineIPs=make_set(IPAddress, 200), BaselineCountries=make_set(Country, 50) by UserUpn;

// ---- 3) Pull sign-ins AFTER click and score “unfamiliar” indicators ----
let PostClickSignins =
ClickedUsers
| join kind=inner (
    SigninLogs
    | where TimeGenerated > ago(clickLookback + postClickWindow)
    | extend Country = tostring(LocationDetails.countryOrRegion),
             State   = tostring(LocationDetails.state),
             City    = tostring(LocationDetails.city),
             DeviceId = tostring(DeviceDetail.deviceId),
             DeviceName = tostring(DeviceDetail.displayName)
    | project SignInTime=TimeGenerated, UserUpn=UserPrincipalName, AppDisplayName, IPAddress,
              Country, State, City, ClientAppUsed, ConditionalAccessStatus,
              ResultType, ResultDescription, DeviceName, DeviceId, UserAgent, CorrelationId
) on UserUpn
| where SignInTime between (FirstClick .. FirstClick + postClickWindow)
| join kind=leftouter Baseline on UserUpn
| extend
    IsSuccess = (ResultType == 0),
    IsNewIP = iff(isempty(BaselineIPs), true, IPAddress !in (BaselineIPs)),
    IsNewCountry = iff(isempty(BaselineCountries), true, Country !in (BaselineCountries)),
    RiskScore =
        (iif(IsSuccess and IsNewIP, 3, 0)) +
        (iif(IsSuccess and IsNewCountry, 2, 0)) +
        (iif(IsSuccess and ConditionalAccessStatus !~ "success", 1, 0));  // CA weirdness
;

// ---- 4) Outputs: summary per user + suspicious sign-ins details ----
let PerUserSummary =
PostClickSignins
| summarize
    PostClickSignins=count(),
    PostClickSuccess=countif(IsSuccess),
    NewIPSuccess=countif(IsSuccess and IsNewIP),
    NewCountrySuccess=countif(IsSuccess and IsNewCountry),
    MaxRiskScore=max(RiskScore),
    SeenApps=make_set(AppDisplayName, 15),
    SeenIPs=make_set(IPAddress, 15),
    SeenCountries=make_set(Country, 15),
    FirstPostClick=min(SignInTime),
    LastPostClick=max(SignInTime)
  by UserUpn;

let SuspiciousSignins =
PostClickSignins
| where IsSuccess and (IsNewIP or IsNewCountry or RiskScore >= 3)
| project UserUpn, SignInTime, AppDisplayName, IPAddress, Country, State, City,
          ClientAppUsed, ConditionalAccessStatus, ResultType, ResultDescription,
          DeviceName, DeviceId, UserAgent, CorrelationId, IsNewIP, IsNewCountry, RiskScore
| order by RiskScore desc, SignInTime desc;

// Final output (two “sections” in one result set)
union
(
  ClickedUsers
  | join kind=leftouter PerUserSummary on UserUpn
  | extend Section="Summary (clicked users + post-click sign-in risk)"
  | project Section, UserUpn, ClickCount, FirstClick, LastClick,
            PostClickSignins, PostClickSuccess, NewIPSuccess, NewCountrySuccess, MaxRiskScore,
            SeenCountries, SeenIPs, SeenApps, SampleUrls
),
(
  SuspiciousSignins
  | extend Section="Details (suspicious post-click successful sign-ins)"
)
| order by Section asc
