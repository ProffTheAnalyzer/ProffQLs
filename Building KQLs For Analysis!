This flags “likely anonymized access” by focusing on new IP + new country for that user over 90 days. (working)

let userUpn = "example@gmail.com";
let baseline = 90d;
let recent = 7d;

let baselinePairs =
SigninLogs
| where TimeGenerated between (ago(baseline) .. ago(recent))
| where UserPrincipalName =~ userUpn
| where ResultType == 0
| extend Country = tostring(LocationDetails.countryOrRegion)
| extend PairKey = strcat(IPAddress, "|", Country)
| summarize by PairKey;

SigninLogs
| where TimeGenerated > ago(recent)
| where UserPrincipalName =~ userUpn
| where ResultType == 0
| extend Country = tostring(LocationDetails.countryOrRegion)
| extend PairKey = strcat(IPAddress, "|", Country)
| where PairKey !in (baselinePairs)
| project TimeGenerated, AppDisplayName, IPAddress, Country, ClientAppUsed,
          ConditionalAccessStatus, UserAgent, CorrelationId
| order by TimeGenerated desc



Add a “churn” view: how many distinct IPs/countries per day for that user:

