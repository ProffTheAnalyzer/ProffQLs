let userUpn = "example@gmail.com";
let lookback = 14d;
let minGap = 5m;
let maxGap = 1d;
let maxSpeedKmh = 900.0;
let earthRadiusKm = 6371.0;

SigninLogs
| where TimeGenerated > ago(lookback)
| where UserPrincipalName =~ userUpn
| where ResultType == 0
| extend
    lat = todouble(tostring(LocationDetails.geoCoordinates.latitude)),
    lon = todouble(tostring(LocationDetails.geoCoordinates.longitude)),
    Country = tostring(LocationDetails.countryOrRegion),
    City = tostring(LocationDetails.city)
| where isnotnull(lat) and isnotnull(lon)
| sort by TimeGenerated asc
| serialize
| extend
    prevTime = prev(TimeGenerated),
    prevIP = prev(IPAddress),
    prevLat = prev(lat),
    prevLon = prev(lon),
    prevCountry = prev(Country),
    prevCity = prev(City)
| extend dt = TimeGenerated - prevTime
| where dt between (minGap .. maxGap)
// Haversine distance (km)
| extend
    dLat = (lat - prevLat) * pi() / 180.0,
    dLon = (lon - prevLon) * pi() / 180.0,
    a = pow(sin(dLat / 2.0), 2.0) + cos(prevLat * pi() / 180.0) * cos(lat * pi() / 180.0) * pow(sin(dLon / 2.0), 2.0),
    distKm = 2.0 * earthRadiusKm * asin(sqrt(a)),
    speedKmh = distKm / (dt / 1h)
| where speedKmh > maxSpeedKmh and distKm > 300.0
| project
    UserPrincipalName=userUpn,
    PrevTime=prevTime, TimeGenerated,
    PrevIP=prevIP, IPAddress,
    PrevCountry=prevCountry, Country,
    PrevCity=prevCity, City,
    distKm, speedKmh, dt,
    AppDisplayName, ClientAppUsed, ConditionalAccessStatus, UserAgent, CorrelationId
| order by speedKmh desc


DeviceFile Activities: 

This query finds devices that have the file on the disk and shows exactly when they last ran it.

DeviceFileEvents
| where FileName =~ "example.exe"
| project DeviceId, DeviceName, FilePath = FolderPath, last_seen_on_disk = Timestamp
| join kind=inner (
    DeviceProcessEvents
    | where FileName =~ "example.exe"
    | project DeviceId, last_executed = Timestamp, ProcessCommandLine
) on DeviceId
| summarize 
    LastTimeSeenOnDisk = max(last_seen_on_disk), 
    LastTimeExecuted = max(last_executed) 
    by DeviceId, DeviceName, FilePath, ProcessCommandLine


KQL Query: Hunting for Renamed Executables 
We join the DeviceFileEvents (where the rename happens) with DeviceProcessEvents (where it eventually runs)

DeviceFileEvents
| where ActionType == "FileRenamed"
| where FileName =~ "example.exe" // The NEW name
| project RenameTime = Timestamp, DeviceId, NewName = FileName, OriginalName = PreviousFileName, FolderPath
| join kind=inner (
    DeviceProcessEvents
    | where FileName =~ "example.exe"
    | project ExecutionTime = Timestamp, DeviceId, ProcessCommandLine, AccountName
) on DeviceId
| where ExecutionTime > RenameTime // Ensure it ran AFTER it was renamed
| project RenameTime, ExecutionTime, DeviceId, OriginalName, NewName, ProcessCommandLine, AccountName


This version removes private IPs and common "System" accounts to show you only the unusual activity.

DeviceProcessEvents
| where FileName =~ "schtasks.exe"
// 1. Filter out the noise: only look for User accounts or suspicious processes
| where AccountName !in~ ("system", "local service", "network service")
| project TaskCreationTime = Timestamp, DeviceId, DeviceName, ProcessCommandLine, AccountName, ProcessId
| join kind=inner (
    DeviceNetworkEvents
    | project NetworkTime = Timestamp, DeviceId, RemoteIP, RemoteUrl, InitiatingProcessId
) on DeviceId
// 2. The "Time Window" - happened within 5 minutes of each other
| where NetworkTime between (TaskCreationTime .. (TaskCreationTime + 5m))
// 3. The "Internal Filter" - only show connections to the INTERNET
| where ipv4_is_private(RemoteIP) == false
| project TaskCreationTime, NetworkTime, DeviceName, AccountName, RemoteIP, RemoteUrl, ProcessCommandLine


Lateral Movement (Admin)

DeviceLogonEvents
| where AccountName has "admin" 
| where ActionType == "LogonSuccess"
| where IsLocalAdmin == true // Boolean check (no quotes)
| project LogonTime = Timestamp, AccountName, DeviceName, DeviceId
| join kind=inner (
    DeviceProcessEvents
    | where FileName has_any ("powershell.exe", "cmd.exe")
    | project ExecutionTime = Timestamp, AccountName, DeviceName, DeviceId, FileName, ProcessCommandLine
) on AccountName, DeviceId // Join on BOTH user and machine
| where ExecutionTime between (LogonTime .. (LogonTime + 30m)) // The "Immediately" part
| project LogonTime, ExecutionTime, DeviceName, AccountName, FileName, ProcessCommandLine


